# Dev Spaces OAuth for Azure DevOps (cluster-level)
#
# This configures OAuth 2.0 for Azure DevOps at the Dev Spaces operator level.
# All users will be able to clone ADO repos without individual PAT setup.
#
# Prerequisites:
# - Microsoft Entra ID app registration with:
#   - Redirect URI: https://devspaces.<cluster-subdomain>/api/oauth/callback
#   - API permission: vso.code_write
#   - ADO organization connected to the Entra ID tenant
#
# Apply to the openshift-devspaces namespace:
#   oc apply -f devspaces-oauth-config.yaml -n openshift-devspaces
#
kind: Secret
apiVersion: v1
metadata:
  name: azure-devops-oauth-config
  namespace: openshift-devspaces
  labels:
    app.kubernetes.io/part-of: che.eclipse.org
    app.kubernetes.io/component: oauth-scm-configuration
  annotations:
    che.eclipse.org/oauth-scm-server: azure-devops
stringData:
  tenant-id: <your-entra-tenant-id>
  id: <your-app-client-id>
  secret: <your-app-client-secret>

# Azure Pipelines Agent Secrets
#
# To use:
# 1. Copy this file to agent-secrets.yaml (it's gitignored)
# 2. Fill in your Azure DevOps configuration
# 3. Apply with: oc apply -f agent-secrets.yaml
#
# Prerequisites:
# - Azure DevOps organization
# - Personal Access Token with "Agent Pools (Read & manage)" scope
# - Self-hosted Agent Pool created in Azure DevOps
#
apiVersion: v1
kind: Secret
metadata:
  name: azure-pipelines-agent
  namespace: azure-pipelines
type: Opaque
stringData:
  VSTS_ACCOUNT: <your-org>
  VSTS_TOKEN: <your-pat-token>
  VSTS_POOL: <your-pool-name>

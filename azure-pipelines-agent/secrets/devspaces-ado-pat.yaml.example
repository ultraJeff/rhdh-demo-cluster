# Dev Spaces PAT for Azure DevOps (per-user)
#
# This secret allows Dev Spaces workspaces to clone Azure DevOps repos.
# Apply to each user's Dev Spaces namespace (<username>-devspaces).
#
# The che-userid is REQUIRED or the operator will delete this secret.
# Get it with:
#   oc get secret user-profile -n <username>-devspaces -o jsonpath='{.data.id}' | base64 -d
#
kind: Secret
apiVersion: v1
metadata:
  name: personal-access-token-azure-devops
  labels:
    app.kubernetes.io/component: scm-personal-access-token
    app.kubernetes.io/part-of: che.eclipse.org
  annotations:
    che.eclipse.org/che-userid: <devspaces-user-id>
    che.eclipse.org/scm-personal-access-token-name: azure-devops
    che.eclipse.org/scm-url: https://dev.azure.com
    che.eclipse.org/scm-username: <your-ado-username-or-email>
    che.eclipse.org/scm-organization: <your-ado-org>
data:
  token: <base64-encoded-pat>
type: Opaque

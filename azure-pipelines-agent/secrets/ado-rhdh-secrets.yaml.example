# Azure DevOps credentials for RHDH integration
#
# To use:
# 1. Copy this file to ado-rhdh-secrets.yaml (it's gitignored)
# 2. Fill in your Azure DevOps configuration
# 3. Apply with: oc apply -f ado-rhdh-secrets.yaml
#
# Generate AZURE_TOKEN_BASE64 with:
#   echo -n ":YOUR_PAT_TOKEN" | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: ado-credentials
  namespace: rhdh
type: Opaque
stringData:
  AZURE_TOKEN: <your-pat-token>
  AZURE_TOKEN_BASE64: <base64-of-colon-pat>
  AZURE_ORG: <your-org>

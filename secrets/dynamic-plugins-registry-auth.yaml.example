# Registry auth for RHDH dynamic plugins (registry.redhat.io)
#
# Required for OCI plugins from registry.redhat.io (e.g. Ansible automation-portal).
# The init container uses this to authenticate skopeo pulls.
#
# To create from the cluster's global pull secret:
#   oc get secret pull-secret -n openshift-config -o jsonpath='{.data.\.dockerconfigjson}' | base64 -d > /tmp/auth.json
#   oc create secret generic dynamic-plugins-registry-auth -n rhdh --from-file=auth.json=/tmp/auth.json
#   rm /tmp/auth.json
#
# This file is just a reference — the secret is best created via the commands above.
apiVersion: v1
kind: Secret
metadata:
  name: dynamic-plugins-registry-auth
  namespace: rhdh
type: Opaque
data:
  auth.json: <base64-encoded-dockerconfigjson>

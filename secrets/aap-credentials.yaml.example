# AAP credentials for RHDH Ansible plugin integration
#
# To use:
# 1. Copy this file to aap-credentials.yaml (it's gitignored)
# 2. Fill in your AAP controller URL and token
# 3. Apply with: oc apply -f secrets/aap-credentials.yaml
#
# Get AAP_TOKEN from AAP controller UI: Users > admin > Tokens > Add
# AAP_BASE_URL is the AAP controller route, e.g. https://aap-aap.apps.<cluster>/
#
apiVersion: v1
kind: Secret
metadata:
  name: aap-credentials
  namespace: rhdh
type: Opaque
stringData:
  AAP_TOKEN: <your-aap-token>
  AAP_BASE_URL: <your-aap-controller-url>
